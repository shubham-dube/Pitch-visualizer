# ── Required ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
# ── App settings ──────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,
# ── Storage (served via StaticFiles) ──────────────────────────
STORAGE_PATH=/app/storage/images
STATIC_URL_PREFIX=/static/images
# ── Generation defaults ───────────────────────────────────────
DEFAULT_IMAGE_MODEL=gemini
CLAUDE_MODEL=claude-sonnet-4-5
DALLE_QUALITY=hd